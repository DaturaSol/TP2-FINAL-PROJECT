# ./docker/Dockerfile.dev
# Developer image for TP2-FINAL-PROJECT
# Multi-arch (amd64 + arm64) via python:3.12-slim-bookworm
FROM python:3.12-slim-bookworm

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# uv install + basic config
# Pinned tag (not :latest) so every teammate gets the identical uv build.
COPY --from=ghcr.io/astral-sh/uv:0.9 \
    /uv /uvx /usr/local/bin/

# Tell uv to put the venv at /workspace/src/back_end/.venv
ENV UV_PROJECT_ENVIRONMENT=/workspace/src/back_end/.venv \
    UV_LINK_MODE=copy \
    PATH="/workspace/src/back_end/.venv/bin:$PATH"

# Docker-in-Docker preconfig if ever necessary.
# Docker CLI + Compose + Buildx
# COPY --from=docker:cli /usr/local/bin/docker /usr/local/bin/docker
# COPY --from=docker/compose-bin:latest /docker-compose /usr/libexec/docker/cli-plugins/docker-compose
# COPY --from=docker/buildx-bin:latest  /buildx        /usr/libexec/docker/cli-plugins/docker-buildx
# RUN ln -s /usr/libexec/docker/cli-plugins/docker-compose /usr/local/bin/docker-compose

# Node.js + pnpm
# NOTE: the NodeSource setup_22.x script prints a deprecation warning and may
# stop working in the future. It is fine for this project's lifetime. If it ever
# breaks, switch to the keyring-based apt method from NodeSource's docs.
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && corepack enable \
    && corepack prepare pnpm@10 --activate

WORKDIR /workspace